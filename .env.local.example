# Local development only (gitignored in .env.local).
# Legacy admin token fallback (optional when using login/session auth).
# If you still use it, keep both values identical.
ADMIN_TOKEN=dev-local-token
VITE_ADMIN_TOKEN=dev-local-token

# Optional backend runtime profile: development | production
ENVIRONMENT=development

# Optional auth session config (backend)
AUTH_COOKIE_NAME=AI_APP_AUTH
AUTH_SESSION_TTL_HOURS=12

# Default seeded users (backend)
# user: zhangsan, admin: lisi
USER_DEFAULT_PASSWORD=ChangeMe_User_123!
ADMIN_DEFAULT_PASSWORD=ChangeMe_Admin_123!
