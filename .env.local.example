# Local development only (gitignored in .env.local).
# Legacy admin token fallback (optional when using login/session auth).
# If you still use it, keep both values identical.
ADMIN_TOKEN=dev-local-token
VITE_ADMIN_TOKEN=dev-local-token

# Optional backend runtime profile: development | production
ENVIRONMENT=development

# Optional single-host port layout.
APP_HOST=0.0.0.0
APP_PORT=80
BACKEND_DEV_PORT=8000
FRONTEND_DEV_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional local MySQL overrides.
# Keep DATABASE_URL/TEST_DATABASE_URL pointed at Docker MySQL or replace host/port for a remote MySQL service.
DATABASE_URL=mysql+pymysql://ai_app_user:ai_app_password@127.0.0.1:13306/ai_app_square?charset=utf8mb4
TEST_DATABASE_URL=mysql+pymysql://ai_app_user:ai_app_password@127.0.0.1:13306/ai_app_square_test?charset=utf8mb4

# Optional auth session config (backend)
AUTH_COOKIE_NAME=AI_APP_AUTH
AUTH_SESSION_TTL_HOURS=12
# Optional external user sync token (enables /api/integration/users/sync when non-empty)
USER_SYNC_TOKEN=

# Default seeded users (backend)
# user: zhangsan, admin: lisi
USER_DEFAULT_PASSWORD=ChangeMe_User_123!
ADMIN_DEFAULT_PASSWORD=ChangeMe_Admin_123!
