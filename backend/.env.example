# Copy this file to backend/.env and keep all application variables here.

# Required: primary MySQL database URL (development / production).
DATABASE_URL=mysql+pymysql://ai_app_user:ai_app_password@127.0.0.1:13306/ai_app_square?charset=utf8mb4

# Recommended: dedicated MySQL database for tests.
TEST_DATABASE_URL=mysql+pymysql://ai_app_user:ai_app_password@127.0.0.1:13306/ai_app_square_test?charset=utf8mb4

# Runtime profile: development | production
ENVIRONMENT=development

# Python package installation source for production hosts.
# Development keeps the default public PyPI behavior.
# Production installs default to `--no-build-isolation` so offline/internal hosts
# do not re-download setuptools/wheel during editable install.
# Set PIP_USE_BUILD_ISOLATION=true only when you explicitly need isolated builds.
PIP_INDEX_URL_PRODUCTION=http://136.142.12.68/simple/
PIP_TRUSTED_HOST_PRODUCTION=136.142.12.68
# PIP_USE_BUILD_ISOLATION=false

# Host and ports
# FRONTEND_BASE_PATH is only for building frontend release artifacts on the
# development machine. It is not a backend runtime setting in backend/.env.
APP_HOST=0.0.0.0
APP_PORT=80
BACKEND_DEV_PORT=8000
FRONTEND_DEV_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:8000
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ALLOWED_HOSTS=127.0.0.1,localhost,testserver
# Leave unset to follow the safe default:
# - development: docs enabled
# - production: docs disabled
# ENABLE_API_DOCS=false

# Static paths
STATIC_DIR=static
UPLOAD_DIR=static/uploads
IMAGE_DIR=static/images

# External integrations
OA_RULE_BASE_URL=https://oa.example.internal
USER_SYNC_TOKEN=

# Auth/session
AUTH_PROVIDER_MODE=local
AUTH_COOKIE_NAME=AI_APP_AUTH
# Leave unset to follow the safe default:
# - development: insecure cookies allowed for local HTTP
# - production: Secure cookies required
# Set AUTH_COOKIE_SECURE=false only when an internal production-like host
# is still served over plain HTTP and cannot terminate HTTPS yet.
# AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_HOURS=12
OA_SSO_LOGIN_URL=
EXTERNAL_SSO_LOGIN_URL=

# Seeded default passwords (must be changed in production)
USER_DEFAULT_PASSWORD=ChangeMe_User_123!
ADMIN_DEFAULT_PASSWORD=ChangeMe_Admin_123!
